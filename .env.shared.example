# Copy to .env.shared and replace the token placeholder before shared deployment.
# This file is a template only; never commit a real token.
APP_ENV=production
DATA_DIR=/app/data
API_AUTH_REQUIRED=true
# Inject API_AUTH_TOKEN at deployment time; leave this blank in the template.
API_AUTH_TOKEN=
API_AUTH_TOKENS=
API_AUDIT_ENABLED=true
API_DEFAULT_TENANT_ID=
TENANT_STORAGE_ISOLATION=true

# The Streamlit UI is local-only. Keep it outside the protected API deployment.
STREAMLIT_APP_ENV=local
STREAMLIT_API_AUTH_REQUIRED=false
STREAMLIT_TENANT_STORAGE_ISOLATION=false
