APP_ENV=production
DATA_DIR=./data
DATABASE_URL=sqlite:///./data/app.db
REDIS_URL=redis://localhost:6379/0
API_AUTH_REQUIRED=true
API_AUTH_TOKEN=
# Optional JSON object for role-specific API tokens.
# Example: {"viewer-token":"viewer","operator-token":{"role":"operator","actor":"batch-operator"}}
API_AUTH_TOKENS=
API_AUDIT_ENABLED=true
API_DEFAULT_TENANT_ID=default
TENANT_STORAGE_ISOLATION=true
# Optional local-only Streamlit Compose profile overrides. These do not affect the protected API service.
STREAMLIT_APP_ENV=local
STREAMLIT_API_AUTH_REQUIRED=false
STREAMLIT_TENANT_STORAGE_ISOLATION=false
ENABLE_AGENT_REVIEW=false
# Optional parser AI review. Turn it on only after selecting a provider and model.
# Supported: openai, azure-openai, anthropic, openai-compatible.
LLM_PROVIDER=openai
# Local RAG chat runtime. Default extractive mode makes no LLM calls.
# For local Llama via Ollama, use RAG_LLM_BACKEND=ollama and RAG_LLM_ENDPOINT=http://127.0.0.1:11434.
RAG_LLM_BACKEND=extractive
RAG_LLM_ENDPOINT=
RAG_LLM_MODEL=
RAG_LLM_TIMEOUT_SECONDS=30
RAG_LLM_MAX_OUTPUT_CHARS=2000
RAG_RATE_LIMIT_REQUESTS_PER_WINDOW=120
RAG_RATE_LIMIT_WINDOW_SECONDS=60
# Leave provider keys empty for no-call local operation.
OPENAI_API_KEY=
OPENAI_COMPATIBLE_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE_URL=https://api.anthropic.com
AGENT_REVIEW_MODEL=gpt-4.1-mini
AGENT_REVIEW_API_BASE_URL=https://api.openai.com
AGENT_REVIEW_TIMEOUT_SECONDS=60
AGENT_REVIEW_TRIGGER_SCORE_BELOW=100.0
AGENT_REVIEW_MAX_CHUNKS_PER_DOCUMENT=20
AGENT_REVIEW_MAX_INPUT_TOKENS_PER_DOCUMENT=15000
AGENT_REVIEW_MAX_DOCUMENTS_PER_BATCH=0
AGENT_REVIEW_MAX_INPUT_TOKENS_PER_BATCH=0
AGENT_REVIEW_MAX_TOTAL_TOKENS_PER_BATCH=0
AGENT_REVIEW_MAX_OUTPUT_TOKENS_PER_CHUNK=512
AGENT_REVIEW_TOKEN_SAFETY_MARGIN=1.25
AGENT_REVIEW_CHARS_PER_TOKEN=4
AGENT_REVIEW_INPUT_PRICE_PER_1M_TOKENS=0
AGENT_REVIEW_OUTPUT_PRICE_PER_1M_TOKENS=0
AGENT_REVIEW_MAX_COST_PER_BATCH=0
AGENT_REVIEW_BUDGET_CURRENCY=USD
AGENT_REVIEW_PRICE_VERSION=
AGENT_REVIEW_PRICE_EFFECTIVE_AT=
ENABLE_KORDOC_TABLE_PARSER=true
# 표 파싱은 Kordoc CLI로 수행합니다. 사전에 kordoc을 설치해 PATH에 올려두세요:
#   npm install -g kordoc     (설치하면 기본값 'kordoc' 그대로 동작 — Windows .cmd 셈도 자동 처리)
# 다른 위치의 실행파일을 쓰려면 전체 명령을 지정할 수 있습니다(예: node로 빌드본 실행):
#   KORDOC_TABLE_COMMAND=node /path/to/kordoc/dist/cli.js
KORDOC_TABLE_COMMAND=kordoc
KORDOC_TABLE_TIMEOUT_SECONDS=120
KORDOC_TABLE_MAX_TABLES=500
MAX_UPLOAD_MB=1000
MAX_BATCH_UPLOAD_MB=1000
MAX_BATCH_UPLOAD_FILES=100
MAX_JSON_REQUEST_BODY_MB=192
HWP_MAX_DECOMPRESSED_SECTION_MB=256
HWP_MAX_DECOMPRESSED_DOCUMENT_MB=512
OFFICE_ARCHIVE_MAX_ENTRIES=4096
OFFICE_ARCHIVE_MAX_FILE_MB=128
OFFICE_ARCHIVE_MAX_TOTAL_UNCOMPRESSED_MB=256
OFFICE_ARCHIVE_MAX_ENTRY_UNCOMPRESSED_MB=64
OFFICE_ARCHIVE_MAX_COMPRESSION_RATIO=200
OFFICE_ARCHIVE_MAX_MEMBER_NAME_CHARS=512
DEFAULT_MAX_CHUNK_CHARS=1800
DEFAULT_OVERLAP_CHARS=120
QUALITY_PROFILES_PATH=
QUALITY_PROFILES_STRICT=false
INSTITUTION_PROFILES_PATH=
INSTITUTION_PROFILES_STRICT=false
